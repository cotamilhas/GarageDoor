@page "/mods/{Id:int}"
@rendermode InteractiveServer
@using PLGarageFrontend.Models
@using PLGarageFrontend.Services
@inject PLGarageService PLGarage

<HeadContent>
    <link rel="stylesheet" href="css/trackdetail.css" />
</HeadContent>

<PageTitle>@(creation?.Name ?? "Mod") – @instanceName</PageTitle>

@if (loading)
{
    <p>Loading...</p>
}
else if (creation == null)
{
    <h1>Mod not found</h1>
}
else
{
    <div class="track-detail-header">
        <div class="track-detail-preview">
            <img src="@($"{PLGarage.BaseUrl}/player_creations/{creation.Id}/preview_image.png")"
                 alt="@creation.Name"
                 onerror="this.parentElement.innerHTML='No preview'" />
        </div>
        <div class="track-detail-meta">
            <h1>@creation.Name</h1>
            <p>by <a href="/players/@creation.PlayerId">@creation.Username</a></p>
            @if (!string.IsNullOrWhiteSpace(creation.Description))
            {
                <p>@creation.Description</p>
            }
            <p class="track-detail-stats">♥ @creation.Hearts | ⬇ @creation.Downloads | 👁 @creation.Views</p>
            <div class="tag-container">
                @if (creation.IsTeamPick)
                {
                    <span class="tag-badge tag-teampick">⭐ Team Pick</span>
                }
                @foreach (var tag in creation.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <span class="tag-badge">@tag</span>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private TrackCreation? creation;
    private string instanceName = "PL Garage";
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var nameTask = PLGarage.GetInstanceNameAsync();
        var creationTask = PLGarage.GetCreationByIdAsync(Id);
        await Task.WhenAll(nameTask, creationTask);
        instanceName = nameTask.Result;
        creation = creationTask.Result;
        loading = false;
    }
}
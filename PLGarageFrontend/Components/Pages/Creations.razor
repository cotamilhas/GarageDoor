@page "/tracks"
@rendermode InteractiveServer
@using PLGarageFrontend.Models
@using PLGarageFrontend.Services
@inject PLGarageService PLGarage

<PageTitle>Tracks – @instanceName</PageTitle>

<div class="main-content">
    <h1>Tracks</h1>

    <div class="controls-row">
        <div class="button-group">
            <button @onclick="() => SetGame(GameMode.LBPK)" disabled="@(gameMode == GameMode.LBPK)">LBP Karting</button>
            <button @onclick="() => SetGame(GameMode.MNR)" disabled="@(gameMode == GameMode.MNR)">ModNation Racers</button>
            <button @onclick="() => SetGame(GameMode.MNRRT)" disabled="@(gameMode == GameMode.MNRRT)">Road Trip</button>
        </div>
    </div>

    <div class="controls-row">
        <input type="search"
               placeholder="Search tracks..."
               @bind="keyword"
               @bind:event="oninput"
               @onkeydown="OnSearchKeyDown" />

        <select @bind="sortColumn" @bind:after="ReloadAsync">
            <option value="created_at">Newest</option>
            <option value="hearts">Most Hearted</option>
            <option value="downloads">Most Downloaded</option>
            <option value="races_started">Most Played</option>
            <option value="rating_up">Highest Rated</option>
            <option value="views">Most Viewed</option>
        </select>
    </div>

    @if (loading)
    {
        <p>Loading...</p>
    }
    else if (result?.Tracks is { Count: 0 })
    {
        <p>No tracks found.</p>
    }
    else if (result is not null)
    {
        <p>Showing @result.Tracks.Count of @result.Total tracks — Page @result.Page / @result.TotalPages</p>

        <div class="track-list">
            @foreach (var track in result.Tracks)
            {
                <div class="track-card">
                    <a href="/tracks/@track.Id">
                        <div class="track-preview">
                            <img src="@($"{PLGarage.BaseUrl}/player_creations/{track.Id}/preview_image.png")"
                                 alt="@track.Name"
                                 onerror="this.style.display='none'; this.parentElement.innerHTML='No preview'" />
                        </div>
                    </a>
                    <div class="track-info">
                        <div class="track-name">
                            <a href="/tracks/@track.Id">@track.Name</a>
                            <span style="font-weight: normal; font-size: 0.9rem; color: #666;">
                                by <a href="/players/@track.PlayerId">@track.Username</a>
                            </span>
                        </div>
                        
                        @if (!string.IsNullOrWhiteSpace(track.Description))
                        {
                            <div class="track-description">@track.Description</div>
                        }
                        
                        <div class="track-stats">
                            ♥ @track.Hearts | ⬇ @track.Downloads | 🏁 @track.RacesStarted | 👁 @track.Views
                        </div>

                        <div class="tag-container">
                            @if (track.NumLaps > 0)
                            {
                                <span class="tag-badge">@track.NumLaps laps</span>
                            }
                            @if (!string.IsNullOrEmpty(track.RaceType))
                            {
                                <span class="tag-badge">@track.RaceType</span>
                            }
                            @if (!string.IsNullOrEmpty(track.Difficulty))
                            {
                                <span class="tag-badge">@track.Difficulty</span>
                            }
                            @if (track.IsTeamPick)
                            {
                                <span class="tag-badge tag-teampick">⭐ Team Pick</span>
                            }
                            @foreach (var tag in track.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <span class="tag-badge">@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="pagination-bar">
            <button disabled="@(result.Page <= 1)" @onclick="PrevPage">← Prev</button>
            <span>Page @result.Page of @result.TotalPages</span>
            <button disabled="@(result.Page >= result.TotalPages)" @onclick="NextPage">Next →</button>
        </div>
    }
</div>

@code {
    private CreationsPage? result;
    private bool loading = true;
    private int page = 1;
    private string instanceName = "PL Garage";
    private string sortColumn = "created_at";
    private string keyword = "";
    private enum GameMode { LBPK, MNR, MNRRT }
    private GameMode gameMode = GameMode.LBPK;

    protected override async Task OnInitializedAsync()
    {
        instanceName = await PLGarage.GetInstanceNameAsync();
        await ReloadAsync();
    }

    private async Task SetGame(GameMode mode)
    {
        gameMode = mode;
        page = 1;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        bool isMnr = gameMode != GameMode.LBPK;
        string platform = gameMode == GameMode.MNRRT ? "PSV" : "PS3";
        result = await PLGarage.GetTracksAsync(page, sortColumn: sortColumn, keyword: keyword, isMnr: isMnr, platform: platform);
        loading = false;
    }

    private async Task PrevPage()
    {
        if (page > 1) { page--; await ReloadAsync(); }
    }

    private async Task NextPage()
    {
        if (result is not null && page < result.TotalPages) { page++; await ReloadAsync(); }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { page = 1; await ReloadAsync(); }
    }
}